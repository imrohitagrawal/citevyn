# CiteVyn AI local environment template.
#
# Copy to `.env` (which is git-ignored) and adjust as needed. Values
# shown match the defaults baked into `app.core.config.Settings`.

# Demo bearer token required for non-admin endpoints.
CITEVYN_DEMO_API_KEY=local-demo-key

# Admin key for /internal/v1/* endpoints (ingestion, index promotion).
CITEVYN_ADMIN_API_KEY=local-admin-key

# Async SQLAlchemy URL. SQLite (aiosqlite) is used in tests; the
# recommended local development URL points at the docker-compose
# `db` service.
CITEVYN_DATABASE_URL=postgresql+psycopg://citevyn:citevyn@localhost:5432/citevyn

# Optional database settings.
CITEVYN_DATABASE_ECHO=false
CITEVYN_DATABASE_POOL_SIZE=5

# Header used to propagate a request identifier (incoming or generated).
CITEVYN_REQUEST_ID_HEADER=X-Request-ID

# Optional: enable the `postgres` pytest marker against a real Postgres
# server (e.g. `uv run pytest -m postgres`). When unset, those tests
# are skipped with an explicit reason so the default `uv run pytest`
# flow stays hermetic against in-memory SQLite.
# CITEVYN_PG_TEST_URL=postgresql+psycopg://citevyn:citevyn@localhost:5432/citevyn_pg_test

# Slice 3 — answer generation. `stub` is the default; switch to
# `anthropic` to enable live `AnthropicMessagesClient` calls.
# CITEVYN_LLM_PROVIDER=stub
# CITEVYN_LLM_MODEL=claude-opus-4-8
# CITEVYN_LLM_MAX_TOKENS=1024
# CITEVYN_LLM_TEMPERATURE=0.2
# CITEVYN_ANTHROPIC_API_KEY=...   # required only when LLM_PROVIDER=anthropic
# CITEVYN_ANTHROPIC_API_BASE=https://api.anthropic.com
# CITEVYN_ANTHROPIC_API_VERSION=2023-06-01
# CITEVYN_ANTHROPIC_TIMEOUT_SECONDS=30.0

# Slice 3 — embeddings.
# CITEVYN_EMBEDDING_PROVIDER=stub
# CITEVYN_EMBEDDING_MODEL=voyage-3
# CITEVYN_EMBEDDING_DIM=1024

# Slice 4 — retrieval & answer engine.
# CITEVYN_RETRIEVAL_TOP_K=6
# CITEVYN_RETRIEVAL_MAX_CANDIDATES=20
# CITEVYN_ANSWER_POLICY_VERSION=v1
# CITEVYN_CACHE_TTL_SECONDS=86400
# CITEVYN_CACHE_ENABLED=true
# CITEVYN_UNSUPPORTED_REFUSAL="I can answer questions about Claude, Claude Code, Codex, and Gemini using indexed official documentation. I do not have credible source material in this assistant to answer that."
# CITEVYN_NO_ANSWER_FALLBACK="I do not have credible source material in this assistant to answer that."
# CITEVYN_INDEX_SESSION_TTL_SECONDS=86400
# CITEVYN_FIXTURES_ROOT=backend/fixtures/sources
