# ────────────────────────────────────────────────────────────────────────────
# CiteVyn production environment.
#
# Copy this file to .env next to docker-compose.yml and fill in the
# real values. docker compose reads .env automatically; the values
# here are NOT suitable for committing.
#
# Required — _env_guard.sh REFUSES every prod entry point until all of
# these are set. Secrets have a 16-character floor and must not be the
# published default (the same test Settings._is_weak_secret applies, so
# the guard fails fast instead of letting the api crash-loop at boot):
#   POSTGRES_PASSWORD              — strong random (32+ chars)
#   CITEVYN_ADMIN_API_KEY          — strong random (32+ chars); used
#                                    for the /v1/admin/* routes. The
#                                    default 'local-admin-key' is
#                                    rejected by the Settings prod
#                                    validator.
#   CITEVYN_DEMO_API_KEY           — strong random (32+ chars); the
#                                    bearer every public /api/v1 request
#                                    carries. 'local-demo-key' is
#                                    rejected. NB it is also baked into
#                                    the browser bundle at BUILD time —
#                                    re-run `make demo-frontend` after
#                                    changing it, or the demo 401s.
#   CITEVYN_PUBLIC_HOST            — the hostname Caddy serves and the
#                                    release gate probes
#   CITEVYN_DATABASE_URL           — postgresql+psycopg://…
#   CITEVYN_LLM_PROVIDER           — must NOT be "stub" in production
#   CITEVYN_ACME_EMAIL             — Let's Encrypt expiry notifications
#   CITEVYN_ANTHROPIC_API_KEY      — required when
#                                    CITEVYN_LLM_PROVIDER=anthropic
#
# Generate a secret with:  openssl rand -hex 32
#
# Optional:
#   VERSION                        — image tag (defaults to "dev");
#                                    set from CI via git tag / commit SHA.
#   CITEVYN_LLM_PROVIDER           — "stub" | "anthropic" (default: stub)
#   CITEVYN_LLM_MODEL              — provider-specific model id (default: empty)
# ────────────────────────────────────────────────────────────────────────────

# Image tag (set by CI from git describe --tags --always)
VERSION=dev

# Postgres
POSTGRES_DB=citevyn
POSTGRES_USER=citevyn
# Generate via: openssl rand -hex 32
POSTGRES_PASSWORD=

# Caddy / TLS
# The host the API is served on. Used by Caddy to mint the
# Let's Encrypt cert. MUST be a public DNS name pointing at
# this host. ACME HTTP-01 challenge is served on :80.
CITEVYN_PUBLIC_HOST=citevyn.example.com

# ACME contact email. Let's Encrypt uses this address to
# notify the operator about expiring certs, so it must be a
# real inbox you monitor. The dev default
# (``dev@local.invalid``) and a missing value are both refused
# by infra/docker/scripts/_env_guard.sh — replace this
# placeholder with a real email before running any prod entry
# point. The guard's error message lists this variable alongside
# POSTGRES_PASSWORD and CITEVYN_ADMIN_API_KEY as required.
CITEVYN_ACME_EMAIL=ops@example.com

# Admin auth (used by /v1/admin/*). Rejected in production if left at
# the default 'local-admin-key'.
CITEVYN_ADMIN_API_KEY=

# Demo auth (the bearer every /v1/* route requires). This is the auth for the
# ENTIRE public demo surface, so it is a real secret, not a formality: leave it
# unset and the app falls back to the code default 'local-demo-key', which is
# published in this open-source repo. Rejected in production for exactly that
# reason (see Settings._reject_default_demo_key_in_production).
#
# It is also REQUIRED by `make deploy-verify`, which authenticates its functional
# probes with it. Its absence from this template is why that gate could not run:
# it died at preflight with "CITEVYN_DEMO_API_KEY is unset".
CITEVYN_DEMO_API_KEY=

# LLM provider. Left EMPTY on purpose: _env_guard.sh rejects "stub" for a
# prod deploy, so shipping stub here meant a literal
# `cp prod.env.example .env` could not pass the guard even after the
# operator filled in every blank. Set gemini | anthropic | openrouter.
CITEVYN_LLM_PROVIDER=
CITEVYN_ANTHROPIC_API_KEY=

# Browser origins allowed to call the API. The code default is
# ('http://localhost:3000',) — see DEFAULT_CORS_ALLOWED_ORIGINS in
# backend/app/core/config.py — so a bundle served from the public host is
# CORS-blocked until this is set, even with a correct demo key.
CITEVYN_CORS_ALLOWED_ORIGINS=https://citevyn.example.com
CITEVYN_LLM_MODEL=

# Database URL used by the host-side scripts (deploy.sh / refresh.sh
# run alembic on the host, not inside the api container). Points at
# the loopback-published port on the db container. The api / worker
# containers use the docker-network URL ``db:5432`` which is
# interpolated by docker-compose.yml from POSTGRES_PASSWORD.
CITEVYN_DATABASE_URL=postgresql+psycopg://citevyn:${POSTGRES_PASSWORD}@127.0.0.1:5432/citevyn

# Rate-limit knobs
CITEVYN_RATE_LIMIT_ENABLED=true
CITEVYN_RATE_LIMIT_WINDOW_SECONDS=3600
CITEVYN_RATE_LIMIT_DEMO_USER_PER_HOUR=30
CITEVYN_RATE_LIMIT_ADMIN_PER_HOUR=1000

# --- Per-visitor rate-limit identity (#203) ---
# The demo API key is SHARED, so it cannot identify a visitor. Without the
# settings below every visitor shares ONE bucket and 30 questions from one
# person deny the demo to everyone else for a rolling hour.
#
# Header to trust for the client address. Trusting a header is only safe when
# the app is unreachable EXCEPT through that proxy — true on Fly, where the app
# has no public port of its own. Set to "" to trust nothing and use the socket
# peer instead.
#   Fly, no CDN in front -> Fly-Client-IP    (this deployment)
#   Cloudflare PROXYING  -> CF-Connecting-IP (only if the orange cloud is on)
#   plain reverse proxy  -> X-Forwarded-For  (leftmost entry is used)
CITEVYN_RATE_LIMIT_CLIENT_IP_HEADER=Fly-Client-IP
# Buckets are keyed on a salted HMAC of the address — a raw IP is personal data
# and an unsalted hash of an IPv4 address is reversible by brute force. Leave
# empty to reuse CITEVYN_DEMO_API_KEY, which is already a required strong secret.
CITEVYN_RATE_LIMIT_KEY_SALT=
# Backstop across ALL visitors, so a distributed source still meets a ceiling.
# Deliberately generous — if this ever binds during ordinary use it has
# re-created the #203 lockout. 0 disables it. NB this bounds REQUEST VOLUME,
# not money; the daily budget below is what caps spend.
CITEVYN_RATE_LIMIT_GLOBAL_PER_HOUR=600

# §9 daily spend ceiling. THIS is the control that caps money — the per-hour
# limits above are fairness/anti-nuisance, not a budget (a distributed source
# still costs you). Summed in SQL from ``provider_calls`` since midnight UTC, so
# it survives a restart, and fail-closed: an unreadable meter stops paid calls
# rather than becoming an unmetered window.
#
# Soft = warn and prefer cache, answers unchanged. Hard = stop paid generation;
# cached answers and exact lookup still serve, and callers see a transient 5xx,
# never a content refusal.
#
# Set to the owner's real ceiling of $2/day. The code defaults are $5/$10, which
# are the upstream reference values, not this deployment's policy.
CITEVYN_COST_SOFT_DAILY_USD=1
CITEVYN_COST_HARD_DAILY_USD=2

# Redis URL — required in production so the rate limiter uses the
# atomic Lua path. The compose file wires this into the api + worker
# containers on the docker network (host: ``redis``).
CITEVYN_REDIS_URL=redis://redis:6379/0
CITEVYN_REDIS_KEY_PREFIX=citevyn:rl
