# RAG eval golden set (Phase 0, issue #96) — one JSON object per line.
# Schema + conventions: tests/eval/README.md. Anchored to the CONFTEST seed
# corpus (backend/tests/conftest.py::seed_catalog) — the 5-chunk corpus the
# hermetic harness + CI run against. Blank lines and #-comment lines are skipped.
#
# kind=literal    -> shares vocabulary with the seed; keyword/exact arm can hit.
# kind=paraphrase -> zero literal overlap w/ the answer text; isolates the dead
#                    semantic/vector arm (#97) — expected ~0 hit-rate at baseline.
# kind=refusal    -> out-of-corpus / off-domain; MUST retrieve nothing + decline.
#
# --- literal (all 5 product areas) --------------------------------------------
{"id": "claude_api_lit_ratelimit", "area": "claude_api", "kind": "literal", "question": "What is the rate limit for the Claude API?", "expected_source": "claude_api", "expected_gist": "The Claude API default rate limit is 50 requests per minute.", "expect_no_answer": false}
{"id": "claude_api_lit_envvar", "area": "claude_api", "kind": "literal", "question": "Which environment variable overrides the Claude API rate limit?", "expected_source": "claude_api", "expected_gist": "The CLAUDE_API_RATE_LIMIT environment variable overrides the default rate limit.", "expect_no_answer": false}
{"id": "claude_code_lit_permissions", "area": "claude_code", "kind": "literal", "question": "How are permissions configured in Claude Code?", "expected_source": "claude_code", "expected_gist": "Claude Code permissions are configured in the project's settings file.", "expect_no_answer": false}
{"id": "claude_code_lit_allowdeny", "area": "claude_code", "kind": "literal", "question": "What do the allow and deny lists do in Claude Code?", "expected_source": "claude_code", "expected_gist": "Allow/deny lists gate which tools and commands the assistant can run.", "expect_no_answer": false}
{"id": "codex_lit_modelflag", "area": "codex", "kind": "literal", "question": "What does the --model flag do in Codex?", "expected_source": "codex", "expected_gist": "The --model flag selects which model Codex uses for code generation.", "expect_no_answer": false}
{"id": "codex_lit_help", "area": "codex", "kind": "literal", "question": "How do I list all Codex CLI flags?", "expected_source": "codex", "expected_gist": "Run 'codex --help' to see the full list of CLI flags.", "expect_no_answer": false}
{"id": "gemini_api_lit_authheader", "area": "gemini_api", "kind": "literal", "question": "Which header carries the Gemini API key?", "expected_source": "gemini_api", "expected_gist": "Pass the Gemini API key in the x-goog-api-key header.", "expect_no_answer": false}
{"id": "gemini_api_lit_credfile", "area": "gemini_api", "kind": "literal", "question": "Can the Gemini CLI read the key from a credentials file?", "expected_source": "gemini_api", "expected_gist": "The Gemini CLI can read the API key from a credentials file.", "expect_no_answer": false}
{"id": "citevyn_lit_pro", "area": "citevyn", "kind": "literal", "question": "What do I get with CiteVyn Pro?", "expected_source": "citevyn", "expected_gist": "CiteVyn Pro is not live yet; it is planned to add higher rate limits, exact lookups, saved history, and shareable answers.", "expect_no_answer": false}
{"id": "citevyn_lit_free", "area": "citevyn", "kind": "literal", "question": "Is CiteVyn free to use right now?", "expected_source": "citevyn", "expected_gist": "CiteVyn is a free MVP demo; everything is currently free to try.", "expect_no_answer": false}
