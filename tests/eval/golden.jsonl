{"id": "claude_api_par_throttle", "area": "claude_api", "kind": "paraphrase", "question": "How quickly does Claude throttle heavy usage?", "expected_source": "claude_api", "expected_gist": "The Claude API throttles at a default of 50 requests per minute.", "expect_no_answer": false}
{"id": "claude_code_par_toolgate", "area": "claude_code", "kind": "paraphrase", "question": "How do I restrict which tools the coding assistant may run?", "expected_source": "claude_code", "expected_gist": "Use Claude Code's allow/deny lists in the settings file to restrict which tools and commands run.", "expect_no_answer": false}
