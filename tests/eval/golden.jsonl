# --- multihop (cross-product; HIT only when EVERY expected area is retrieved) ---
{"id": "multihop_ratelimit_vs_auth", "area": "cross_product", "kind": "multihop", "question": "How do the rate limits for the Claude API compare to how you authenticate to the Gemini API?", "expected_sources": ["claude_api", "gemini_api"], "expected_gist": "Covers BOTH: the Claude API's 50 requests/minute rate limit AND authenticating to the Gemini API via the x-goog-api-key header."}
{"id": "multihop_auth_compare", "area": "cross_product", "kind": "multihop", "question": "How does authentication differ between the Gemini API and the Claude API?", "expected_sources": ["claude_api", "gemini_api"], "expected_gist": "Covers BOTH the Gemini API (x-goog-api-key header) and the Claude API (its key / rate-limited access)."}
{"id": "multihop_code_vs_codex", "area": "cross_product", "kind": "multihop", "question": "What do Claude Code permissions and the Codex --model flag each control?", "expected_sources": ["claude_code", "codex"], "expected_gist": "Covers BOTH: Claude Code allow/deny permission lists AND the Codex --model flag selecting the model."}
# --- followup (multi-turn; final turn is anaphoric + names no product → resolves only
#     with conversation memory, Phase 3b. history = prior USER turns, chronological). ---
{"id": "followup_claude_api_raise", "area": "claude_api", "kind": "followup", "history": ["What is the rate limit for the Claude API?"], "question": "How can I raise it?", "expected_source": "claude_api", "expected_gist": "Raise the Claude API rate limit by setting the CLAUDE_API_RATE_LIMIT environment variable to override the default 50 requests per minute."}
{"id": "followup_gemini_api_altkey", "area": "gemini_api", "kind": "followup", "history": ["Which header carries the Gemini API key?"], "question": "Is there another way to provide it?", "expected_source": "gemini_api", "expected_gist": "Yes — besides the x-goog-api-key header, the Gemini CLI can also read the API key from a credentials file."}
{"id": "followup_codex_otherflags", "area": "codex", "kind": "followup", "history": ["What does the --model flag do in Codex?"], "question": "How do I see the others?", "expected_source": "codex", "expected_gist": "Run 'codex --help' to see the full list of Codex CLI flags besides --model."}
