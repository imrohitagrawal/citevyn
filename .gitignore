!.claude/skills/
.claude/skills/*
!.claude/skills/rag-eval/

# Logs
*.log
logs/

# Build
dist/
build/

# Node, if frontend is added later
node_modules/
.next/
coverage/
# frontend/ — node_modules and build artefacts only; source files are tracked
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo

# Docker/local data
*.db
*.sqlite
data/
tmp/

# Production runtime artefacts (volumes are bind-mounted; data
# is owned by the host user, not the repo).
infra/docker/backups/citevyn-*.dump
infra/docker/caddy_data/
infra/docker/caddy_config/
infra/docker/citevyn_pgdata/

# Playwright live-mode report dir
playwright-report-live/

# Generated eval / golden run reports (make eval / make golden write here)
artifacts/
