# CiteVyn frontend environment (Vite).
#
# Copy to `.env.local` and adjust. Every var is optional — the client
# ships safe defaults so `npm run dev` works against the Vite proxy with
# no .env at all. Only `VITE_*` names are exposed to the browser bundle.

# Backend base URL. Leave EMPTY for local dev: Vite proxies `/v1` and
# `/health` to http://127.0.0.1:8000 (see vite.config.ts), so requests
# stay same-origin (no CORS preflight). Set this only for a production
# build that points at a deployed backend, e.g. https://api.citevyn.com
VITE_API_BASE_URL=

# Demo bearer token. Must match the backend's CITEVYN_DEMO_API_KEY.
# Default (client-side): local-demo-key
VITE_API_DEMO_KEY=local-demo-key

# user_id sent when creating a session. Default: demo_user
VITE_API_DEMO_USER_ID=demo_user

# Live/demo toggle for the chat. Default is DEMO (canned knowledgeBase
# answers, no network). Set to "true" to route the chat through the real
# backend (POST /v1/sessions + /messages). Any other value = demo.
VITE_API_LIVE=false
