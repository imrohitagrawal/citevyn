    { "q": "anti-citevyn rant", "match": true, "why": "canonical branch is un-guarded" },
    { "q": "mycitevynapp", "match": false, "why": "canonical is word-bounded" },

    { "q": "what is sitewin?", "match": true, "why": "single-token alias" },
    { "q": "what is citevin?", "match": true, "why": "single-token alias" },
